{
  "basic": {
    "description": "基础配置",
    "type": "object",
    "hint": "插件基础功能配置",
    "items": {
      "enabled_groups": {
        "type": "list",
        "description": "允许使用功能的QQ群列表",
        "default": [],
        "hint": "只有在列表中的群才能触发插件功能，为空则允许所有群"
      },
      "bg_api_url": {
        "type": "string",
        "description": "背景图片API地址",
        "default": "https://t.alcy.cc/ycy",
        "hint": "用于签到卡片背景的随机图片API。若失败则使用本地备用图。"
      },
      "enable_image_card": {
        "type": "bool",
        "description": "是否启用图片卡片",
        "default": true,
        "hint": "关闭后，签到和查询将只发送文字信息，不生成图片卡片。"
      },
      "currency_name": {
        "type": "string",
        "description": "货币名称",
        "default": "金币",
        "hint": "用于所有涉及货币的提示信息，如金币、钻石、水晶等。"
      },
      "maintenance_mode": {
        "type": "bool",
        "description": "维护模式开关",
        "default": false,
        "hint": "开启后仅允许使用价格、我的信息等查询指令，其他操作会提示维护中。"
      }
    }
  },
  "trade": {
    "description": "交易配置",
    "type": "object",
    "hint": "购买、出售、赎身等交易相关配置",
    "items": {
      "takeover_fee_rate": {
        "type": "float",
        "description": "恶意收购额外费用率",
        "default": 0.1,
        "hint": "例如，0.1代表收购他人雇员时，需额外支付10%的费用作为转让费。"
      },
      "sell_return_rate": {
        "type": "float",
        "description": "主动出售返还率",
        "default": 0.8,
        "hint": "例如，0.8代表主动出售雇员时，可以收回其当前身价的80%。"
      },
      "redeem_return_rate": {
        "type": "float",
        "description": "赎身时原雇主得款率",
        "default": 0.5,
        "hint": "例如，0.5代表当雇员赎身时，原雇主可以获得其赎身费用的50%作为补偿。"
      },
      "min_purchase_price": {
        "type": "float",
        "description": "最低购买价格",
        "default": 100,
        "hint": "购买时的最低价格，如果目标身价低于此值，则按此值计算。管理员加成在此基础上计算。"
      }
    }
  },
  "contract": {
    "description": "契约配置",
    "type": "object",
    "hint": "雇员契约等级相关配置",
    "items": {
      "employed_income_rate": {
        "type": "float",
        "description": "被雇佣时收入惩罚率",
        "default": 0.7,
        "hint": "例如，0.7代表被雇佣的玩家签到时，最终收益只有正常的70%。"
      },
      "contract_level_price_bonus": {
        "type": "float",
        "description": "每级契约身价加成",
        "default": 0.15,
        "hint": "例如，0.15代表玩家的契约等级每提升1级，其身价在基础之上增加15%。"
      },
      "contract_level_rate_bonus": {
        "type": "float",
        "description": "每级契约增益加成",
        "default": 0.075,
        "hint": "例如，0.075代表玩家的契约等级每提升1级，为雇主提供的收益加成额外增加7.5%。"
      },
      "admin_contractor_bonus": {
        "type": "float",
        "description": "管理员雇员额外加成",
        "default": 0.1,
        "hint": "例如，0.1代表每雇佣一个管理员，该雇员为雇主提供的收益加成额外增加10%。"
      },
      "wealth_value_bonus_rate": {
        "type": "float",
        "description": "身价加成系数",
        "default": 0.001,
        "hint": "雇员身价影响雇主收益的系数。计算公式：身价/1000*系数。例如0.001代表身价10000的雇员额外提供1%的加成。"
      }
    }
  },
  "admin": {
    "description": "管理员配置",
    "type": "object",
    "hint": "群主/管理员相关配置",
    "items": {
      "admin_price_bonus": {
        "type": "float",
        "description": "管理员价格加成比例",
        "default": 0.5,
        "hint": "例如，0.5代表管理员身价加成50%，管理员可被购买但价格更高。"
      },
      "super_admins": {
        "type": "list",
        "description": "超级管理员QQ号列表",
        "default": [],
        "hint": "超级管理员可以使用特殊指令（如give指令），不受群组限制。填写QQ号字符串。"
      }
    }
  },
  "at_reward": {
    "description": "At机器人奖励配置",
    "type": "object",
    "hint": "用户at机器人时随机获得金币奖励的配置",
    "items": {
      "enable_at_reward": {
        "type": "bool",
        "description": "是否启用at机器人奖励",
        "default": true,
        "hint": "开启后，用户at机器人有概率获得随机金币奖励。"
      },
      "at_reward_probability": {
        "type": "float",
        "description": "获得奖励的概率",
        "default": 0.3,
        "hint": "0-1之间的小数，例如0.3代表30%的概率获得奖励。"
      },
      "at_reward_min": {
        "type": "float",
        "description": "最小奖励金额",
        "default": 1.0,
        "hint": "每次at获得奖励时的最小金币数。"
      },
      "at_reward_max": {
        "type": "float",
        "description": "最大奖励金额",
        "default": 10.0,
        "hint": "每次at获得奖励时的最大金币数。"
      },
      "at_reward_daily_limit": {
        "type": "int",
        "description": "每日奖励上限次数",
        "default": 5,
        "hint": "每个成员每天最多获得奖励的次数。"
      },
      "at_reward_timezone": {
        "type": "string",
        "description": "时区设置",
        "default": "Asia/Shanghai",
        "hint": "用于每日奖励次数重置的时区。常用时区：Asia/Shanghai（中国）、Asia/Tokyo（日本）、America/New_York（美国东部）、Europe/London（伦敦）。"
      }
    }
  },
  "stock_market": {
    "description": "股市配置",
    "type": "object",
    "hint": "汇率市场相关配置，模拟股票市场波动",
    "items": {
      "base_exchange_rate": {
        "type": "float",
        "description": "基准汇率",
        "default": 1.0,
        "hint": "1群主货币 = X 货币"
      },
      "volatility": {
        "type": "float",
        "description": "波动率",
        "default": 0.02,
        "hint": "几何布朗运动波动率参数"
      },
      "mean_reversion_speed": {
        "type": "float",
        "description": "均值回归速度",
        "default": 0.1,
        "hint": "均值回归速度参数"
      },
      "mean_reversion_level": {
        "type": "float",
        "description": "均值回归水平",
        "default": 1.0,
        "hint": "长期均衡汇率"
      },
      "update_interval_minutes": {
        "type": "int",
        "description": "更新间隔",
        "default": 60,
        "hint": "汇率更新间隔（分钟）"
      },
      "update_probability": {
        "type": "float",
        "description": "更新概率",
        "default": 1.0,
        "hint": "每次到达更新间隔时，实际执行汇率更新的概率（0-1）。例如0.5代表50%概率更新，使汇率波动更自然。"
      },
      "history_days": {
        "type": "int",
        "description": "历史天数",
        "default": 7,
        "hint": "汇率历史保存天数"
      },
      "trend_mode": {
        "type": "string",
        "description": "趋势模式",
        "default": "off",
        "hint": "汇率趋势模式：random=随机自动切换牛熊，fixed=使用固定趋势方向，off=关闭趋势（默认均值回归）"
      },
      "trend_direction": {
        "type": "int",
        "description": "固定趋势方向",
        "default": 0,
        "hint": "trend_mode=fixed时有效。1=牛市（上涨），-1=熊市（下跌），0=震荡"
      },
      "trend_bull_probability": {
        "type": "int",
        "description": "牛市概率",
        "default": 30,
        "hint": "trend_mode=random时，随机进入牛市的概率（百分比）"
      },
      "trend_bear_probability": {
        "type": "int",
        "description": "熊市概率",
        "default": 30,
        "hint": "trend_mode=random时，随机进入熊市的概率（百分比）"
      },
      "trend_range_probability": {
        "type": "int",
        "description": "震荡概率",
        "default": 40,
        "hint": "trend_mode=random时，随机进入震荡市的概率（百分比）。三个概率之和应等于100"
      },
      "trend_min_days": {
        "type": "int",
        "description": "趋势最少持续天数",
        "default": 3,
        "hint": "trend_mode=random时，趋势至少持续的天数"
      },
      "trend_max_days": {
        "type": "int",
        "description": "趋势最多持续天数",
        "default": 10,
        "hint": "trend_mode=random时，趋势最多持续的天数"
      },
      "trend_min_strength": {
        "type": "float",
        "description": "最小趋势强度",
        "default": 0.01,
        "hint": "每天趋势影响的最小幅度，例如0.01代表每天最少1%的趋势影响"
      },
      "trend_max_strength": {
        "type": "float",
        "description": "最大趋势强度",
        "default": 0.05,
        "hint": "每天趋势影响的最大幅度，例如0.05代表每天最多5%的趋势影响"
      },
      "rate_limit": {
        "description": "使用次数限制",
        "type": "object",
        "hint": "股市命令每日使用次数限制配置",
        "items": {
          "enable_rate_limit": {
            "type": "bool",
            "description": "启用次数限制",
            "default": true,
            "hint": "开启后，汇率查询、购买、出售命令将有每日次数限制"
          },
          "base_exchange_query": {
            "type": "int",
            "description": "汇率查询基础次数",
            "default": 3,
            "hint": "平民等级每日可查询汇率的次数"
          },
          "base_buy": {
            "type": "int",
            "description": "购买基础次数",
            "default": 2,
            "hint": "平民等级每日可购买群主币的次数"
          },
          "base_sell": {
            "type": "int",
            "description": "出售基础次数",
            "default": 2,
            "hint": "平民等级每日可出售群主币的次数"
          },
          "wealth_level_bonus": {
            "type": "int",
            "description": "财富等级次数加成",
            "default": 1,
            "hint": "每提升一个财富等级，每日次数上限增加的次数。例如：平民3次，小资3+1=4次"
          }
        }
      },
      "cleanup_interval_hours": {
        "type": "int",
        "description": "汇率历史清理间隔",
        "default": 24,
        "hint": "自动清理旧汇率历史记录的时间间隔（小时），默认24小时"
      },
      "cleanup_keep_days": {
        "type": "int",
        "description": "汇率历史保留天数",
        "default": 30,
        "hint": "汇率历史记录保留的天数，超过此天数的记录将被自动清理"
      },
      "trading_hours": {
        "type": "template_list",
        "description": "交易时段配置",
        "hint": "配置多个交易时段，支持上午盘、下午盘、夜盘等。默认使用中国股市交易时间（周一至周五 9:30-11:30, 13:00-15:00）。留空则全天可交易。",
        "templates": {
          "trading_session": {
            "name": "交易时段",
            "hint": "定义一个交易时段的时间和生效星期",
            "items": {
              "name": {
                "type": "string",
                "description": "时段名称",
                "default": "上午盘",
                "hint": "给这个交易时段起个名字，如上午盘、下午盘、夜盘等"
              },
              "start_time": {
                "type": "string",
                "description": "开始时间",
                "default": "09:30",
                "hint": "交易时段开始时间，格式 HH:MM，如 09:30"
              },
              "end_time": {
                "type": "string",
                "description": "结束时间",
                "default": "11:30",
                "hint": "交易时段结束时间，格式 HH:MM，如 11:30"
              },
              "weekdays": {
                "type": "list",
                "description": "生效星期",
                "hint": "选择该时段在星期几生效，可多选",
                "options": ["周一", "周二", "周三", "周四", "周五", "周六", "周日"],
                "default": ["周一", "周二", "周三", "周四", "周五"]
              },
              "enabled": {
                "type": "bool",
                "description": "是否启用",
                "default": true,
                "hint": "关闭后该时段将不生效"
              }
            }
          }
        },
        "default": [
          {
            "name": "上午盘",
            "start_time": "09:30",
            "end_time": "11:30",
            "weekdays": ["周一", "周二", "周三", "周四", "周五"],
            "enabled": true
          },
          {
            "name": "下午盘",
            "start_time": "13:00",
            "end_time": "15:00",
            "weekdays": ["周一", "周二", "周三", "周四", "周五"],
            "enabled": true
          }
        ]
      }
    }
  },
  "redeem_codes": {
    "description": "兑换码配置",
    "type": "template_list",
    "hint": "配置多个兑换码，每个兑换码可设置奖励数量、过期时间、使用次数限制等",
    "templates": {
      "redeem_code": {
        "name": "兑换码",
        "hint": "用户输入兑换码可获得对应奖励",
        "items": {
          "code": {
            "type": "string",
            "description": "兑换码",
            "default": "",
            "hint": "兑换码字符串，用户输入此代码进行兑换。建议设置复杂一些的代码防止被猜测。"
          },
          "description": {
            "type": "string",
            "description": "兑换码描述",
            "default": "",
            "hint": "兑换码的说明文字，如'新春活动奖励'、'推广码'等。"
          },
          "reward_amount": {
            "type": "float",
            "description": "奖励数量",
            "default": 100.0,
            "hint": "兑换成功后用户获得的货币数量。"
          },
          "is_expired": {
            "type": "bool",
            "description": "是否已过期",
            "default": false,
            "hint": "手动设置兑换码是否过期。开启后该兑换码将无法使用。"
          },
          "expire_time": {
            "type": "string",
            "description": "过期时间",
            "default": "",
            "hint": "兑换码过期时间，格式：YYYY-MM-DD HH:MM。留空表示永不过期。"
          },
          "max_uses": {
            "type": "int",
            "description": "最大使用次数",
            "default": 0,
            "hint": "兑换码最多可被使用多少次。0表示无限制。"
          },
          "enabled_groups": {
            "type": "list",
            "description": "允许使用的群列表",
            "default": [],
            "hint": "只有在列表中的群才能使用该兑换码，为空则允许所有群。"
          }
        }
      }
    }
  }
}
